# Python
__pycache__/
*.py[cod]
*.pyo
.env
venv/
.venv/

# 日志（运行时生成）
logs/

# 敏感配置（如果日后迁移到 .env 管理）
.env

# IDE
.vscode/
.idea/

# 运行时生成的数据（含敏感信息）
# data/ 整体纳入版本管理

# 旧版本手动备份（应用 git 版本历史代替）
history/

# PyInstaller 构建产物（可通过 pyinstaller 重新生成）
build_tmp/
*.spec
main.exe
setup_profiles.exe
_run_*.bat

# 文档
README.md

# 分发包内的大文件（不纳入版本管理）
Nstbrowser*.exe
*.zip

# 嵌入式 Python（体积过大，目标机器按 README 自行下载配置）
# 但 VC++ Runtime DLL 需要随仓库分发，目标 Windows Server 通常缺少这些库
python/**
!python/msvcp140*.dll

# OSS 工具与文档
ossutil.exe
OSS操作手册.md
